  "license": "MIT",
  "repository": "",
  "scripts": {
    "task": "bun scripts/task.ts",
    "fmt": "oxfmt",
    "build:test": "bun task build && bun test:bun && bun test:node",
    "test:node": "node --test \"tests/node/**/*.test.ts\"",
    "test:watch:node": "node --test --watch \"tests/node/**/*.test.ts\"",
    "test:bun": "bun test tests/bun --only-failures --pass-with-no-tests",
    "test:watch:bun": "bun test tests/bun --only-failures --pass-with-no-tests",
    "bench:node": "node --expose-gc --allow-natives-syntax",
    "bench:deno": "deno run --allow-all --v8-flags=--expose-gc,--allow-natives-syntax"
  },
  "devDependencies": {
    "@swc/core": "^1.15.18",
    "@types/bun": "^1.3.9",
    "@types/deno": "^2.5.0",
    "@types/node": "^25.5.0",
    "chokidar": "^5.0.0",
    "mitata": "^1.0.34",
    "oxc-transform": "^0.112.0",
    "oxfmt": "^0.32.0",
    "picocolors": "^1.1.1",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "@swc/core"
  ]
}
